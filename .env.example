# Trend Compass environment variables
# Copy to .env.local and fill in values. Never commit .env.local.

# Password gate for the whole app (required in production)
APP_PASSWORD=

# AI providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Market data
EODHD_API_KEY=
FRED_API_KEY=

# Image search for trend illustrations (optional)
PEXELS_API_KEY=

# Redis / KV persistence (optional — falls back to in-memory if unset)
# Examples:
#   REDIS_URL=rediss://default:password@host:port
#   KV_URL=rediss://default:password@host:port
REDIS_URL=
KV_URL=

# Public base URL used for SEO metadata / sitemap
# On Vercel, VERCEL_URL is injected automatically; set this for custom domains.
NEXT_PUBLIC_SITE_URL=
